import { url } from '../utils/url';
---
interface Slide {
  image: string;
  title: string;
  subtitle?: string;
}

interface Props {
  slides?: Slide[];
}

const { slides } = Astro.props;

const defaultSlides: Slide[] = [
  {
    image: '/images/hero/slide1.jpg',
    title: 'バイオテクノロジーの力で、\n持続可能な未来を創る',
    subtitle: 'Creating a sustainable future through biotechnology',
  },
  {
    image: '/images/hero/slide2.jpg',
    title: '最先端のゲノム編集技術で\n社会課題を解決する',
    subtitle: 'Solving social challenges with cutting-edge genome editing',
  },
  {
    image: '/images/hero/slide3.jpg',
    title: 'データ駆動型バイオで\n産業に革新を',
    subtitle: 'Innovation in industry with data-driven bio',
  },
];

const heroSlides = slides || defaultSlides;
---

<section class="relative h-[60vh] sm:h-[70vh] lg:h-[80vh] overflow-hidden">
  <!-- Slides -->
  {heroSlides.map((slide, i) => (
    <div
      class:list={[
        'hero-slide absolute inset-0 transition-opacity duration-1000',
        i === 0 ? 'opacity-100' : 'opacity-0',
      ]}
      data-index={i}
    >
      <div class="absolute inset-0 bg-dark/50 z-10" />
      <div
        class="absolute inset-0 bg-cover bg-center bg-no-repeat"
        style={`background-image: url('${slide.image}'); background-color: #0F1B1E;`}
      />
      <div class="relative z-20 h-full flex items-center justify-center text-center px-4">
        <div>
          <h1 class="text-2xl sm:text-3xl lg:text-5xl font-bold text-white leading-tight whitespace-pre-line">
            {slide.title}
          </h1>
          {slide.subtitle && (
            <p class="mt-4 text-sm sm:text-base text-white/80 font-[var(--font-english)]">
              {slide.subtitle}
            </p>
          )}
          <div class="mt-8">
            <a
              href={url("/contact")}
              class="inline-block px-8 py-3 bg-teal text-white font-medium rounded-lg hover:bg-teal-dark transition-colors"
            >
              お問い合わせ
            </a>
          </div>
        </div>
      </div>
    </div>
  ))}

  <!-- Dots -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30 flex gap-2">
    {heroSlides.map((_, i) => (
      <button
        class:list={[
          'hero-dot w-3 h-3 rounded-full transition-colors',
          i === 0 ? 'bg-white' : 'bg-white/50',
        ]}
        data-index={i}
        aria-label={`スライド ${i + 1}`}
      />
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  let current = 0;
  const total = slides.length;

  function showSlide(index: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('opacity-100', i === index);
      (s as HTMLElement).classList.toggle('opacity-0', i !== index);
    });
    dots.forEach((d, i) => {
      (d as HTMLElement).classList.toggle('bg-white', i === index);
      (d as HTMLElement).classList.toggle('bg-white/50', i !== index);
    });
    current = index;
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt((dot as HTMLElement).dataset.index || '0');
      showSlide(index);
    });
  });

  setInterval(() => {
    showSlide((current + 1) % total);
  }, 5000);
</script>
