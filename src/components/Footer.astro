---
const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Company Info -->
      <div class="lg:col-span-1">
        <a href="/" class="text-2xl font-bold text-teal font-[var(--font-english)]">PtBio</a>
        <p class="mt-2 text-sm text-gray-400">プラチナバイオ株式会社</p>
        <p class="mt-4 text-sm text-gray-400 leading-relaxed">
          〒657-0013<br />
          兵庫県神戸市灘区六甲台町1-1<br />
          神戸大学統合研究拠点内
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">ページ</h3>
        <ul class="space-y-2">
          <li><a href="/company" class="text-sm text-gray-400 hover:text-teal transition-colors">会社概要</a></li>
          <li><a href="/recruitment" class="text-sm text-gray-400 hover:text-teal transition-colors">採用情報</a></li>
          <li><a href="/resources" class="text-sm text-gray-400 hover:text-teal transition-colors">リソース</a></li>
          <li><a href="/blog" class="text-sm text-gray-400 hover:text-teal transition-colors">お知らせ</a></li>
          <li><a href="/contact" class="text-sm text-gray-400 hover:text-teal transition-colors">お問い合わせ</a></li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">サービス</h3>
        <ul class="space-y-2">
          <li><a href="/service/genome" class="text-sm text-gray-400 hover:text-teal transition-colors">ゲノム編集</a></li>
          <li><a href="/service/biodx" class="text-sm text-gray-400 hover:text-teal transition-colors">バイオDX</a></li>
        </ul>
      </div>

      <!-- Contact & Governance -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mb-4">お問い合わせ</h3>
        <ul class="space-y-2">
          <li><a href="/contact" class="text-sm text-gray-400 hover:text-teal transition-colors">お問い合わせフォーム</a></li>
          <li><a href="/contact/document-request" class="text-sm text-gray-400 hover:text-teal transition-colors">資料請求</a></li>
        </ul>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gray-300 mt-6 mb-4">ガバナンス</h3>
        <ul class="space-y-2">
          <li><a href="/company/governance-policy" class="text-sm text-gray-400 hover:text-teal transition-colors">プライバシーポリシー</a></li>
          <li><a href="/company/governance-fraudprevention" class="text-sm text-gray-400 hover:text-teal transition-colors">不正防止対策の基本方針</a></li>
          <li><a href="/company/governance-plan" class="text-sm text-gray-400 hover:text-teal transition-colors">一般事業主行動計画</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-700 text-center">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} プラチナバイオ株式会社 All Rights Reserved.
      </p>
    </div>
  </div>
</footer>
