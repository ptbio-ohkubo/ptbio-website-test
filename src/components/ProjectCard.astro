---
interface Props {
  title: string;
  href: string;
  image?: string;
  description?: string;
  external?: boolean;
}

const { title, href, image, description, external = false } = Astro.props;
const linkProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} {...linkProps} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
  <div class="aspect-[16/10] overflow-hidden bg-light">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-teal/10">
        <span class="text-teal text-4xl">🧬</span>
      </div>
    )}
  </div>
  <div class="p-4 lg:p-5">
    <h3 class="text-sm sm:text-base font-bold text-dark group-hover:text-teal transition-colors">
      {title}
      {external && (
        <svg class="inline-block w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      )}
    </h3>
    {description && (
      <p class="mt-2 text-sm text-text-light line-clamp-3">{description}</p>
    )}
  </div>
</a>
