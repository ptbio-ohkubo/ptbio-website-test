---
interface Props {
  formspreeEndpoint?: string;
  title?: string;
  fields?: Array<{
    name: string;
    label: string;
    type: 'text' | 'email' | 'tel' | 'textarea';
    required?: boolean;
    placeholder?: string;
  }>;
}

const { formspreeEndpoint = '#', title, fields } = Astro.props;

const defaultFields = [
  { name: 'company', label: '会社名', type: 'text' as const, required: true },
  { name: 'department', label: '部署名', type: 'text' as const, required: false },
  { name: 'name', label: 'お名前', type: 'text' as const, required: true },
  { name: 'email', label: 'メールアドレス', type: 'email' as const, required: true },
  { name: 'tel', label: '電話番号', type: 'tel' as const, required: false },
  { name: 'message', label: 'お問い合わせ内容', type: 'textarea' as const, required: true },
];

const formFields = fields || defaultFields;
---

<form action={formspreeEndpoint} method="POST" class="space-y-6">
  {title && (
    <h2 class="text-2xl font-bold text-dark mb-6">{title}</h2>
  )}

  {formFields.map((field) => (
    <div>
      <label for={field.name} class="block text-sm font-medium text-text mb-1">
        {field.label}
        {field.required && <span class="text-red-500 ml-1">*</span>}
      </label>
      {field.type === 'textarea' ? (
        <textarea
          id={field.name}
          name={field.name}
          required={field.required}
          rows={5}
          placeholder={field.placeholder}
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal/50 focus:border-teal outline-none transition-colors resize-y"
        />
      ) : (
        <input
          type={field.type}
          id={field.name}
          name={field.name}
          required={field.required}
          placeholder={field.placeholder}
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal/50 focus:border-teal outline-none transition-colors"
        />
      )}
    </div>
  ))}

  <div>
    <button
      type="submit"
      class="w-full sm:w-auto px-8 py-3 bg-teal text-white font-medium rounded-lg hover:bg-teal-dark transition-colors"
    >
      送信する
    </button>
  </div>
</form>
