import { url } from '../utils/url';
---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsCard from '../components/NewsCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const recentNews = allPosts.slice(0, 3).map((post) => ({
  title: post.data.title,
  date: post.data.date,
  href: `/blog/${post.id}`,
  excerpt: post.data.excerpt,
  thumbnail: post.data.thumbnail,
}));

const projects = [
  { title: '赤紫蘇のデータ駆動型育種', href: '/project/shiso', description: 'ゲノム編集とAI解析で、高品質な赤紫蘇品種の効率的な育種を実現' },
  { title: '眼の希少疾患の遺伝子治療', href: '/project/drug', description: 'Platinum TALEN技術を活用した、眼科領域の革新的遺伝子治療の開発' },
  { title: '卵アレルギーでも、食べられる卵を', href: '/project/egg-for-all', description: 'ゲノム編集により低アレルゲン卵の実現を目指す' },
  { title: '食品廃棄物を有効資源に変える', href: '/project/agriculture', description: 'バイオテクノロジーで食品廃棄物を価値ある資源に変換' },
  { title: 'し尿処理施設をバイオDXで効率化', href: '/project/metagenomic-analysis-for-sewage-treatment', description: 'メタゲノム解析で処理プロセスを最適化' },
  { title: '水産養殖の未来', href: '/project/aquaculture', description: 'ゲノム育種技術で持続可能な水産養殖を実現' },
];

const services = [
  { title: 'ゲノム編集', href: '/service/genome', description: 'Platinum TALENをはじめとする高精度ゲノム編集技術を提供' },
  { title: 'バイオDX', href: '/service/biodx', description: 'ゲノムデータ解析・微生物叢解析などのバイオインフォマティクスサービス' },
];
---

<PageLayout title="トップ" description="プラチナバイオ株式会社 - バイオテクノロジーの力で、持続可能な未来を創る">
  <!-- Hero Carousel -->
  <Hero />

  <!-- News Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="最新情報" subtitle="News" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentNews.map((news) => (
          <NewsCard {...news} />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href={url("/blog")} class="inline-block px-6 py-2 border-2 border-teal text-teal font-medium rounded-lg hover:bg-teal hover:text-white transition-colors">
          一覧を見る
        </a>
      </div>
    </div>
  </section>

  <!-- Feature Section -->
  <section class="py-16 lg:py-24 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="私たちの強み" subtitle="Feature" />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-teal/10 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">独自のゲノム編集技術</h3>
          <p class="text-sm text-text-light">Platinum TALENをはじめとする、高精度・高効率なゲノム編集技術を保有</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-teal/10 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">データ駆動型アプローチ</h3>
          <p class="text-sm text-text-light">バイオインフォマティクスとAIを活用した、データ駆動型の研究開発</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 bg-teal/10 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-dark mb-2">社会実装への挑戦</h3>
          <p class="text-sm text-text-light">研究成果を産業応用し、食・医療・環境の課題解決に貢献</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="プロジェクト" subtitle="Projects" />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project) => (
          <ProjectCard {...project} />
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 lg:py-24 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="サービス" subtitle="Services" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Note Section -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="技術情報" subtitle="Tech Note" />
      <div class="text-center text-text-light">
        <p>技術情報コンテンツは準備中です。</p>
      </div>
    </div>
  </section>

  <!-- Company Section -->
  <section class="py-16 lg:py-24 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading title="会社概要" subtitle="Company" />
      <div class="max-w-3xl mx-auto">
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-gray-200">
              <th class="py-3 pr-4 text-left font-medium text-text w-1/3">会社名</th>
              <td class="py-3 text-text-light">プラチナバイオ株式会社</td>
            </tr>
            <tr class="border-b border-gray-200">
              <th class="py-3 pr-4 text-left font-medium text-text">英文社名</th>
              <td class="py-3 text-text-light">Platinum Bio, Inc.</td>
            </tr>
            <tr class="border-b border-gray-200">
              <th class="py-3 pr-4 text-left font-medium text-text">所在地</th>
              <td class="py-3 text-text-light">〒657-0013 兵庫県神戸市灘区六甲台町1-1 神戸大学統合研究拠点内</td>
            </tr>
          </tbody>
        </table>
        <div class="mt-8 text-center">
          <a href={url("/company")} class="inline-block px-6 py-2 border-2 border-teal text-teal font-medium rounded-lg hover:bg-teal hover:text-white transition-colors">
            詳しく見る
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-dark text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold">お気軽にお問い合わせください</h2>
      <p class="mt-4 text-gray-300">
        ゲノム編集・バイオDXに関するご相談、資料請求など、お気軽にお問い合わせください。
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href={url("/contact")} class="px-8 py-3 bg-teal text-white font-medium rounded-lg hover:bg-teal-dark transition-colors">
          お問い合わせ
        </a>
        <a href={url("/contact/document-request")} class="px-8 py-3 border-2 border-white text-white font-medium rounded-lg hover:bg-white hover:text-dark transition-colors">
          資料請求
        </a>
      </div>
    </div>
  </section>
</PageLayout>
