---
import PageLayout from '../../layouts/PageLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout title="お知らせ" description="プラチナバイオ株式会社のお知らせ・ニュース一覧">
  <section class="py-12 lg:py-20 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal font-[var(--font-english)]">News</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-dark">お知らせ</h1>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <NewsCard
            title={post.data.title}
            date={post.data.date}
            href={`/blog/${post.id}`}
            thumbnail={post.data.thumbnail}
            excerpt={post.data.excerpt}
          />
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-center text-text-light">お知らせはまだありません。</p>
      )}
    </div>
  </section>
</PageLayout>
