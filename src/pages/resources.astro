---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<PageLayout title="リソース" description="プラチナバイオ株式会社のリソース・資料">
  <section class="py-12 lg:py-20 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal font-[var(--font-english)]">Resources</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-dark">リソース</h1>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none text-text-light">
        <p>
          リソースページの詳細はWixサイトから移行時にコンテンツを差し替えてください。
        </p>
      </div>
    </div>
  </section>
</PageLayout>
