---
import PageLayout from '../../layouts/PageLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<PageLayout title="お問い合わせ" description="プラチナバイオへのお問い合わせはこちらから">
  <section class="py-12 lg:py-20 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-teal font-[var(--font-english)]">Contact</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold text-dark">お問い合わせ</h1>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-8">
        ゲノム編集・バイオDXに関するご質問、共同研究のご相談など、お気軽にお問い合わせください。<br />
        <span class="text-red-500">*</span> は必須項目です。
      </p>
      <ContactForm formspreeEndpoint="https://formspree.io/f/YOUR_FORM_ID" />
    </div>
  </section>
</PageLayout>
